// =========================
// server.js (Node.js)
// =========================
// Prérequis:
// 1) Installer Node.js
// 2) npm init -y
// 3) npm install express node-fetch
// 4) node server.js

const express = require('express');
const fetch = require('node-fetch');
const app = express();

// ⚠️ IMPORTANT: garde le webhook CÔTÉ SERVEUR (ne jamais le mettre dans le HTML)
const DISCORD_WEBHOOK = 'REMPLACE_ICI_PAR_TON_WEBHOOK';

app.use(express.json());
app.use(express.static('public'));

// Enregistre une demande et programme l'envoi dans 20 minutes
app.post('/schedule', async (req, res) => {
  const { username } = req.body;
  if (!username) return res.status(400).json({ ok: false, error: 'Nom manquant' });

  // 20 minutes = 1 200 000 ms
  setTimeout(async () => {
    try {
      await fetch(DISCORD_WEBHOOK, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: `Nom Discord programmé: **${username}**` })
      });
      console.log('Message envoyé:', username);
    } catch (e) {
      console.error('Erreur envoi webhook:', e);
    }
  }, 20 * 60 * 1000);

  res.json({ ok: true, scheduledInMinutes: 20 });
});

// ⚠️ Discord ne fournit PAS d’API publique pour vérifier si un nom existe.
// On peut seulement vérifier le FORMAT (caractères valides).
app.post('/check-format', (req, res) => {
  const { username } = req.body;
  const valid = /^[a-zA-Z0-9._]{2,32}$/.test(username || '');
  res.json({ valid, note: 'Vérification du format uniquement (pas de confirmation d’existence)' });
});

app.listen(3000, () => console.log('Serveur lancé sur http://localhost:3000'));


// =========================
// public/index.html
// =========================
